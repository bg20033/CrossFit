ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
ASPNETCORE_FORWARDEDHEADERS_ENABLED=true
AllowedHosts=your-api-domain.com
ConnectionStrings__DefaultConnection=Server=your-aiven-host.aivencloud.com;Port=13353;Database=defaultdb;User=avnadmin;Password=CHANGE_ME;SslMode=Required;
JwtSettings__SecretKey=CHANGE_ME_AT_LEAST_32_RANDOM_CHARS
JwtSettings__ExpiryMinutes=60
JwtSettings__RefreshTokenDays=7
JwtSettings__Issuer=StandUpFitness
JwtSettings__Audience=StandUpFitnessClient
Cors__AllowedOrigins__0=https://your-frontend-domain.com
Email__Provider=log
Email__From=noreply@your-domain.com
Email__Smtp__Host=
Email__Smtp__Port=587
Email__Smtp__EnableSsl=true
Email__Smtp__Username=
Email__Smtp__Password=
Sms__Provider=log
Sms__Twilio__AccountSid=
Sms__Twilio__AuthToken=
Sms__Twilio__From=
Payments__Provider=
Payments__PublicBaseUrl=https://your-api-domain.com
BootstrapAdmin__Email=admin@example.com
BootstrapAdmin__Password=CHANGE_ME_AT_LEAST_8_CHARS
BootstrapAdmin__Name=StandUp CrossFit Admin
BootstrapAdmin__ResetPasswordOnDeploy=false
